                <MODIFICATION>
                  <CHANGE>@@changed("Sonst", "-", "-", "/ODX/DIAG-LAYER-CONTAINER/ECU-VARIANTS/ECU-VARIANT[@ID='EV_Gatew31xUNECE_005']/DIAG-DATA-DICTIONARY-SPEC/DATA-OBJECT-PROPS/DATA-OBJECT-PROP[@ID='DOP_TEXTTABLERecorDataIdentMeasuValue']/COMPU-METHOD/COMPU-INTERNAL-TO-PHYS/COMPU-SCALES/COMPU-SCALE[100]/DESC/p[1]", "Dia_Mes_58526;Der Messwert „Ethernet Zähler Checksummenfehler“ gibt jeweils die Anzahl der Checks-ummenfehler empfangener Ethernet-Frames auf Layer 2 seit dem letzten Klemme-15-Wechsel von AUS nach EIN zurück.", "Dia_Mes_58526;Der Messwert „Ethernet Zähler Checksummenfehler gibt jeweils die Anzahl der Checks-ummenfehler empfangener Ethernet-Frames auf Layer 2 seit dem letzten Klemme-15-Wechsel von AUS nach EIN zurück.")</CHANGE>
                </MODIFICATION>
