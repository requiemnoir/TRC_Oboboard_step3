                <DTC ID="DTCDOP_VAGUDS.DTC_265">
                  <SHORT-NAME>DTC_265</SHORT-NAME>
                  <TROUBLE-CODE>265</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>B200046</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="B200046">EEPROM_Defect_Checksume_Failure_HVK</TEXT>
                  <LEVEL>4</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">Nur Kl_15 EIN oder "autonomer Betrieb"</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
