                  <CHANGE>@@changed("Sonst", "-", "-", "/ODX/DIAG-LAYER-CONTAINER/ECU-VARIANTS/ECU-VARIANT[@ID='EV_Gatew31xUNECE_005']/DIAG-DATA-DICTIONARY-SPEC/DATA-OBJECT-PROPS/DATA-OBJECT-PROP[@ID='DOP_TEXTTABLERecorDataIdentMeasuValue']/COMPU-METHOD/COMPU-INTERNAL-TO-PHYS/COMPU-SCALES/COMPU-SCALE[101]/DESC/p[1]", "Dia_Mes_56405;Der Messwert „Ethernet Zähler Checksummenfehler“ gibt jeweils die Anzahl der Checks-ummenfehler empfangener Ethernet-Frames auf Layer 2 seit dem letzten Klemme-15-Wechsel von AUS nach EIN zurück.", "Dia_Mes_56405;Der Messwert „Ethernet Zähler Checksummenfehler gibt jeweils die Anzahl der Checks-ummenfehler empfangener Ethernet-Frames auf Layer 2 seit dem letzten Klemme-15-Wechsel von AUS nach EIN zurück.")</CHANGE>
                </MODIFICATION>
                <MODIFICATION>
                  <CHANGE>@@changed("Sonst", "-", "-", "/ODX/DIAG-LAYER-CONTAINER/ECU-VARIANTS/ECU-VARIANT[@ID='EV_Gatew31xUNECE_005']/DIAG-DATA-DICTIONARY-SPEC/DATA-OBJECT-PROPS/DATA-OBJECT-PROP[@ID='DOP_TEXTTABLERecorDataIdentMeasuValue']/COMPU-METHOD/COMPU-INTERNAL-TO-PHYS/COMPU-SCALES/COMPU-SCALE[102]/DESC/p[1]", "Dia_Mes_58034;Der Messwert „Ethernet Status Elektrischer Fehler“ muss den aktuellen elektrischen Status des Ethernet-Links mit den folgenden möglichen Werten zurückgeben: 0 = kein elektrischer Fehler 1 = Unterbrechung 2 = Kurzschluss", "Dia_Mes_58034;Der Messwert „Ethernet Status Elektrischer Fehler muss den aktuellen elektrischen Status des Ethernet-Links mit den folgenden möglichen Werten zurückgeben: 0 = kein elektrischer Fehler 1 = Unterbrechung 2 = Kurzschluss")</CHANGE>
                </MODIFICATION>
