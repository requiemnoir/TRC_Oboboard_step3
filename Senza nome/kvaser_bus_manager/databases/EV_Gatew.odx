                <DTC ID="DTCDOP_VAGUDS.DTC_512">
                  <SHORT-NAME>DTC_512</SHORT-NAME>
                  <TROUBLE-CODE>512</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>P168400</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="P168400">Control module programming Malfunction in data transfer</TEXT>
                  <LEVEL>4</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">keine/nicht zutreffend</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">sonstiges Ereignis;zu Begin des Flashen der Connect-Domain wird ein Timer in der Vehicle Domaine aufgezogen. Wenn nach Ablauf des Timers die Connect-Domain nicht wieder in der Applikation läuft, wird der Fehlerspeicher gesetzt</SD>
                      <SD SI="Fehlersetzbedingung">Connect-Domain startet nach Flashen nicht wieder auf</SD>
                      <SD SI="Entstörzeit">900000 ms</SD>
                      <SD SI="Aussetzzeit">0 ms</SD>
                      <SD SI="Funktionelle Einschränkungen">keine Connect-Funktionen</SD>
                      <SD SI="Fehlerbehandlung">Steuergerät erneut flashen</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">n/a</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
                      <SD SI="Rücksetzbedingungen">Connect Domain startet wieder</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
                <DTC ID="DTCDOP_VAGUDS.DTC_611840">
                  <SHORT-NAME>DTC_611840</SHORT-NAME>
                  <TROUBLE-CODE>611840</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>U152200</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="U152200">pncCommunicationError_cGW_MBB</TEXT>
                  <LEVEL>6</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">keine/nicht zutreffend</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">sonstiges Ereignis;Empfang der entsprechenden Nachricht mit unplausiblem/falschen Wert.</SD>
                      <SD SI="Fehlersetzbedingung">pncInstallRootCertContainerAckRes enthält nicht den in pncInstallRootCertContainerAckReq gesendeten Zählerwert</SD>
                      <SD SI="Entstörzeit">0 ms</SD>
                      <SD SI="Aussetzzeit">0 ms</SD>
                      <SD SI="Funktionelle Einschränkungen">Funktion kann nicht oder nur eingeschränkt genutzt werden</SD>
                      <SD SI="Fehlerbehandlung">Bestätigung am Backend nicht korrekt erfolgt; Prozess wird Audi-backendseitig erneut angestoßen; erfolgt Fehler mehrfach liegt Fehler in Audi Backend vor oder Daten sind manipuliert; Mitteilung an Audi Backend</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">n/a</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
                      <SD SI="Rücksetzbedingungen">Ereignisspeichereintrag löschen</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
                <DTC ID="DTCDOP_VAGUDS.DTC_611841">
                  <SHORT-NAME>DTC_611841</SHORT-NAME>
                  <TROUBLE-CODE>611841</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>U152300</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="U152300">pncCertUpdate_NotPossible</TEXT>
                  <LEVEL>6</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">keine/nicht zutreffend</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">sonstiges Ereignis;Bei Zertifikat-Übertragung UND gestecktem Ladestecker</SD>
                      <SD SI="Fehlersetzbedingung">pncInstallRootCertContainerJob oder pncRecvRootCertContainerReq von CU empfangen, wenn Ladestecker gesteckt</SD>
                      <SD SI="Entstörzeit">0 ms</SD>
                      <SD SI="Aussetzzeit">0 ms</SD>
                      <SD SI="Funktionelle Einschränkungen">Funktion kann nicht oder nur eingeschränkt genutzt werden</SD>
                      <SD SI="Fehlerbehandlung">Daten können nicht im Fahrzeug installiert werden, da Ladestecker gesteckt und Zugriff auf Zertifikatespeicher erfolgt. Um Update zu ermöglichen Ladestecker abziehen. Fahrzeug bzw. Backend stoßen Installation automatisch erneut an.</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">n/a</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
                      <SD SI="Rücksetzbedingungen">Ereignisspeichereintrag löschen</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
                <DTC ID="DTCDOP_VAGUDS.DTC_611843">
                  <SHORT-NAME>DTC_611843</SHORT-NAME>
                  <TROUBLE-CODE>611843</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>U112100</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="U112100">pncCommunicationError_cGW_OBC</TEXT>
                  <LEVEL>6</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">keine/nicht zutreffend</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">sonstiges Ereignis;Versenden der Ursprungsnachricht startet Timer. Nach Ablauf Timer ohne Antwort erfolgt Diagnoseeintrag.</SD>
                      <SD SI="Fehlersetzbedingung">Timer wird mit Senden der Nachricht pncInstallRootCertContainerReq gestartet an PnC ECU; wenn innerhalb der definierten Timeout-Zeit pncInstallRootCertContainer_TIMEOUT_CU_PnCECU die Nachricht pncInstallRootCertContainerRAck nicht empfangen wird;</SD>
                      <SD SI="Entstörzeit">0 ms</SD>
                      <SD SI="Aussetzzeit">0 ms</SD>
                      <SD SI="Funktionelle Einschränkungen">Funktion kann nicht oder nur eingeschränkt genutzt werden</SD>
                      <SD SI="Fehlerbehandlung">Kommunikation zu PnC ECU gestört; Rückmeldung der Störung an Backend; Selbstheilung durch automatischesWiederholen des Prozesses, angestoßen durch MBB; Verbindung zum Backend ist sicherzustellen; Verbindung über UDS zwischen PnC ECU und CU muss gegeben sein</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">n/a</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
                      <SD SI="Rücksetzbedingungen">Ereignisspeichereintrag löschen</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
