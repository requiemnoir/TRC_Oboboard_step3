                <DTC ID="DTCDOP_VAGUDS.DTC_16711741">
                  <SHORT-NAME>DTC_16711741</SHORT-NAME>
                  <TROUBLE-CODE>16711741</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>C11C5F1</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="C11C5F1">HVK_Failure_Wire_1</TEXT>
                  <LEVEL>4</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">Nur Kl_15 EIN oder "autonomer Betrieb"</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">Zyklisch;100 ms</SD>
                      <SD SI="Fehlersetzbedingung">Prüfung immer wenn HV Anforderer aktiv: Ungültige Spannungsdifferenz zwischen Istspannung der E-Maschine 1 und HV-Batteriespannung</SD>
                      <SD SI="Entstörzeit">3000 ms</SD>
                      <SD SI="Aussetzzeit">500 ms</SD>
                      <SD SI="Funktionelle Einschränkungen">HV-Netz Abschaltung. Wenn Fehler nicht mehr aktiv kann Netz wieder zugeschalten werden.</SD>
                      <SD SI="Fehlerbehandlung">Beseitigung Spannungsabfall Leitungskreis 1 - im Leitungskreis betroffene Komponenten auf eingetragene Fehler überprüfen (falls vorh. Beheben) - Steckverbindungen/Verkabelung überprüfen (Kabelbruch, offene Steckstellen, Steckerdefekt)</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">(0x2AD0,High_voltage_engaging_prohibition,FFN=71),(0x5825,High_voltage_open_wire_detection,FFN=71)</SD>
                      <SD SI="Warn-Lampen Information">Warnlampe (rot) ausserhalb Fahrtbetrieb im Zustand Fahrtbetrieb nur gelbe Warnlampe mit Text "kein Wiederstart möglich"</SD>
                      <SD SI="Rücksetzbedingungen">Spannungsdifferenz im gültigen Bereich</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
                <DTC ID="DTCDOP_VAGUDS.DTC_16711776">
                  <SHORT-NAME>DTC_16711776</SHORT-NAME>
                  <TROUBLE-CODE>16711776</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>C11C5F2</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="C11C5F2">HVK_Failure_Wire_2</TEXT>
                  <LEVEL>4</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">Nur Kl_15 EIN oder "autonomer Betrieb"</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">Zyklisch;100ms</SD>
                      <SD SI="Fehlersetzbedingung">Prüfung nur bei Systemprüfung nach leichtem Crash oder unklarem EEPROM-Inhalt: Ungültige Spannungdifferenz zwischen Istspannung DCDC-Wandler (+Nebenverbraucher) und HV-Batteriespannung</SD>
                      <SD SI="Entstörzeit">3000 ms</SD>
                      <SD SI="Aussetzzeit">1000 ms</SD>
                      <SD SI="Funktionelle Einschränkungen">HV-Netz Abschaltung. Netz dauerhaft gesperrt bis Rücksetzen durch Routine.</SD>
                      <SD SI="Fehlerbehandlung">Beseitigung Spannungsabfall Leitungskreis 2 - im Leitungskreis betroffene Komponenten auf eingetragene Fehler überprüfen (falls vorh. Beheben) - Steckverbindungen/Verkabelung überprüfen (Kabelbruch, offene Steckstellen, Steckerdefekt) (auch Service-Disconnect) -Crasherkennung nach Reparatur zurücksetzen.</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">(0x2AD0,High_voltage_engaging_prohibition,FFN=71),(0x5825,High_voltage_open_wire_detection,FFN=71)</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
                      <SD SI="Rücksetzbedingungen">Spannungsdifferenz im gültigen Bereich und Crashrücksetzung über Routine</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
