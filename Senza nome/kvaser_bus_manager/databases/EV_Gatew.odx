                <DTC ID="DTCDOP_VAGUDS.DTC_266">
                  <SHORT-NAME>DTC_266</SHORT-NAME>
                  <TROUBLE-CODE>266</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>B200009</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="B200009">NAD_Defekt</TEXT>
                  <LEVEL>4</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">keine</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">Zyklisch;n/a</SD>
                      <SD SI="Fehlersetzbedingung">Defekt in NAD erkannt durch: 1. Erkennung von Überstrom in der NAD-Stromversorgung, wenn 3 mal bei Stromeinschalten des NADs Überstrom erkannt wird, oder 2. SW Überwachung der Kommunication zwischen GW Controller und NAD - Kommunikationausfall bei 3 mal hintereinander liegende Fahrzyklen.</SD>
                      <SD SI="Entstörzeit">keine/nicht zutreffend</SD>
                      <SD SI="Aussetzzeit">keine/nicht zutreffend</SD>
                      <SD SI="Funktionelle Einschränkungen">Eingeschränkte Funktionalität vom Steuergerät</SD>
                      <SD SI="Fehlerbehandlung">Steuergeräte tauschen</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">n/a</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
                      <SD SI="Rücksetzbedingungen">keine/nicht zutreffend</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
                <DTC ID="DTCDOP_VAGUDS.DTC_267">
                  <SHORT-NAME>DTC_267</SHORT-NAME>
                  <TROUBLE-CODE>267</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>B2F0200</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="B2F0200">NAD_Defect_temp</TEXT>
                  <LEVEL>9</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">keine</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">Zyklisch;Der FSP soll gesetzt werden, wenn vom Fail-Safty Watchdog ein Reset des NAD ausgelöst wird (bei jedem Resetversuch). Der FSP soll zurückgesetzt werden, wenn die Fail-Safty-Kommunikation funktioniert und somit kein Resetgrund vorliegt.</SD>
                      <SD SI="Fehlersetzbedingung">SW Überwachung der Kommunication zwischen GW Controller und NAD - Kommunikationausfall bei jedem Auftreten.</SD>
                      <SD SI="Entstörzeit">keine/nicht zutreffend</SD>
                      <SD SI="Aussetzzeit">300000 ms</SD>
                      <SD SI="Funktionelle Einschränkungen">temporär eingeschränkte Funktionalität vom Steuergerät</SD>
                      <SD SI="Fehlerbehandlung">keine</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">n/a</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
                      <SD SI="Rücksetzbedingungen">SW Überwachung der Kommunication zwischen GW Controller und NAD - Kommunikation stabil.</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
                <DTC ID="DTCDOP_VAGUDS.DTC_268">
                  <SHORT-NAME>DTC_268</SHORT-NAME>
                  <TROUBLE-CODE>268</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>B2F0300</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="B2F0300">NAD_Defect_temp_2</TEXT>
                  <LEVEL>9</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">keine</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">Zyklisch;Der FSP soll gesetzt werden, wenn vom Watchdog ein Reset des SPI-Prozessors ausgelöst wird (bei jedem Resetversuch). Der FSP soll zurückgesetzt werden, wenn der SPI-Prozessor wieder funktioniert und somit kein Resetgrund vorliegt.</SD>
                      <SD SI="Fehlersetzbedingung">SW Überwachung der Kommunikation zwischen GW Controller und SPI-Prozessor - Kommunikationausfall bei jedem Auftreten.</SD>
                      <SD SI="Entstörzeit">keine/nicht zutreffend</SD>
                      <SD SI="Aussetzzeit">300000 ms</SD>
                      <SD SI="Funktionelle Einschränkungen">temporär eingeschränkte Funktionalität vom Steuergerät</SD>
                      <SD SI="Fehlerbehandlung">keine</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">n/a</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
