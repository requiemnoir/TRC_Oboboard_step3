                <DTC ID="DTCDOP_VAGUDS.DTC_8978688">
                  <SHORT-NAME>DTC_8978688</SHORT-NAME>
                  <TROUBLE-CODE>8978688</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>B201800</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="B201800">Authentication_failed</TEXT>
                  <LEVEL>4</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">keine/nicht zutreffend</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">sonstiges Ereignis;Einmalig im Anfang eines On/Off-Zyklus (spätestens nach 1 Minute) jedoch nicht im StartUp (Bootvorgang des Steuergerätes) Prüfung nach Einbringen des FSC über die Routine 0xC001.</SD>
                      <SD SI="Fehlersetzbedingung">Signatur des FSC ist nicht gültig</SD>
                      <SD SI="Entstörzeit">0 ms</SD>
                      <SD SI="Aussetzzeit">0 ms</SD>
                      <SD SI="Funktionelle Einschränkungen">Die zum FSC zugehörende Funktion ist nicht freigeschaltet</SD>
                      <SD SI="Fehlerbehandlung">1.- Auslesen des Messwertes 0x3C00 sowie der Umgebungsdaten. 2.- Abgleich des Inhalts von 0x3C00 mit den für das Fahrzeug in Carport hinterlegten Freischaltungen, Ermittlung der Funktionen die erneut freigeschaltet werden müssen. 3.- Erzeugung neuer FSCs für diese Funktionen gemäss Carport Dokumentation. 4.- Einbringen der FSC.s 5.- Löschen des DTC über Diagnose.</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">(0x3C0B,Failure_triggering_FS-ID_with_status,FFN=71)</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
                      <SD SI="Rücksetzbedingungen">Signatur des FSC ist gültig</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
                <DTC ID="DTCDOP_VAGUDS.DTC_8978689">
                  <SHORT-NAME>DTC_8978689</SHORT-NAME>
                  <TROUBLE-CODE>8978689</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>B18D3F4</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="B18D3F4">Fs_id_authentification_failed</TEXT>
                  <LEVEL>4</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">keine/nicht zutreffend</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">sonstiges Ereignis;Einmalig im Anfang eines On/Off-Zyklus (spätestens nach 1 Minute) jedoch nicht im StartUp (Bootvorgang des Steuergerätes) Prüfung nach Einbringen eines FSC im FoD-Master über die Routine 0xC001 oder über online-Schnittstelle.</SD>
                      <SD SI="Fehlersetzbedingung">Signatur des FS-ID-Übertragung ist nicht gültig</SD>
                      <SD SI="Entstörzeit">0 ms</SD>
                      <SD SI="Aussetzzeit">0 ms</SD>
                      <SD SI="Funktionelle Einschränkungen">Die zur FS-ID zugehörende Funktion ist nicht freigeschaltet</SD>
                      <SD SI="Fehlerbehandlung">1.- Erneutes Anlernen Komponentenschutz/VKMS-Schlüssel für FoD-Master und FoD-Slave 2.- Erneuter On/Off-Zyklus. 3.- Löschen des DTC über Diagnose.</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">n/a</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
                      <SD SI="Rücksetzbedingungen">Übertragung mit erfolgreichem Signaturcheck</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
                <DTC ID="DTCDOP_VAGUDS.DTC_8978690">
                  <SHORT-NAME>DTC_8978690</SHORT-NAME>
                  <TROUBLE-CODE>8978690</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>B18D3F2</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="B18D3F2">Fs_id_invalid_configuration</TEXT>
                  <LEVEL>4</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">keine/nicht zutreffend</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">sonstiges Ereignis;Einmalig im Anfang eines On/Off-Zyklus (spätestens nach 1 Minute) jedoch nicht im StartUp (Bootvorgang des Steuergerätes) Prüfung nach Einbringen des FSC über die Routine 0xC001 oder über online-Schnittstelle.</SD>
                      <SD SI="Fehlersetzbedingung">Freigeschaltete FS-ID kann vom FoD-Master nicht gemappt werden.</SD>
                      <SD SI="Entstörzeit">0 ms</SD>
                      <SD SI="Aussetzzeit">0 ms</SD>
                      <SD SI="Funktionelle Einschränkungen">FS-ID ist im Fahrzeug nicht freigeschaltet.</SD>
                      <SD SI="Fehlerbehandlung">1.- Auslesen des Messwertes "SW-Version" des FoD-Master-SG. 2.- Flashen FoD-Master-SG mit korrekter FoD-Master version. 3.- Erneuter On/Off-Zyklus. 4.- Löschen des DTC über Diagnose.</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">n/a</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
                      <SD SI="Rücksetzbedingungen">wenn in FoD Übertragungsrunde nicht mehr aufgetreten</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
                <DTC ID="DTCDOP_VAGUDS.DTC_8978691">
                  <SHORT-NAME>DTC_8978691</SHORT-NAME>
                  <TROUBLE-CODE>8978691</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>B18D3F1</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="B18D3F1">Fs_id_communication_failure</TEXT>
                  <LEVEL>4</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">keine/nicht zutreffend</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">sonstiges Ereignis;Einmalig im Anfang eines On/Off-Zyklus (spätestens nach 1 Minute) jedoch nicht im StartUp (Bootvorgang des Steuergerätes) Prüfung nach Einbringen des FSC über die Routine 0xC001 oder über online-Schnittstelle.</SD>
                      <SD SI="Fehlersetzbedingung">Austausch Challenge ist erfolgt. Slave schickt keine signierte Rückantwort</SD>
                      <SD SI="Entstörzeit">0 ms</SD>
                      <SD SI="Aussetzzeit">0 ms</SD>
                      <SD SI="Funktionelle Einschränkungen">Erhöhung Fehlerzähler im Slave (ggf. Abwurf der Funktion)</SD>
                      <SD SI="Fehlerbehandlung">1.- Auslesen Messwrt 0x0180 im FoD-Master um betroffenen FoD-Slave festzustellen 2.- Prüfen ob gleichzeitg DTC "FoD Master/Slave Signature check failed" im FoD-Slave vorhanden 3.- Wenn ja: Vorgehen wie bei diesem DTC 4.- Wenn nein: Neustart des FoD-Slave-SG, ggf. Austausch 5.- Löschen des DTC über Diagnose.</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">n/a</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
                      <SD SI="Rücksetzbedingungen">wenn in FoD Übertragungsrunden nicht mehr aufgetreten</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
