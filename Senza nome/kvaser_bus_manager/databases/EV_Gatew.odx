                <DTC ID="DTCDOP_VAGUDS.DTC_257">
                  <SHORT-NAME>DTC_257</SHORT-NAME>
                  <TROUBLE-CODE>257</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>B200044</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="B200044">RAM_Defect</TEXT>
                  <LEVEL>4</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">keine</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">Zyklisch;Überwachung ist permanent aktiv (HW-Funktion des Mikro-Controllers)</SD>
                      <SD SI="Fehlersetzbedingung">Bei jedem lesenden Zugriff auf eine RAM-Zelle wird von der Controller HW automatisch der CRC über die gelesenen Datenbits berechnet und mit den abgelegten und ebenfalls gelesenen CRC-Bits verglichen.</SD>
                      <SD SI="Entstörzeit">keine/nicht zutreffend</SD>
                      <SD SI="Aussetzzeit">keine/nicht zutreffend</SD>
                      <SD SI="Funktionelle Einschränkungen">Eingeschränkte Funktionalität vom Steuergerät</SD>
                      <SD SI="Fehlerbehandlung">Steuergeräte Tausch</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">n/a</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
                      <SD SI="Rücksetzbedingungen">keine/nicht zutreffend</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
                <DTC ID="DTCDOP_VAGUDS.DTC_258">
                  <SHORT-NAME>DTC_258</SHORT-NAME>
                  <TROUBLE-CODE>258</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>B200045</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="B200045">ROM_Defect</TEXT>
                  <LEVEL>4</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">keine</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">Zyklisch;Eine permanente Überwachung des Flash-ROMs wird in einem mit niedriger Priorität laufenden Hintergrundprozess umgesetzt.</SD>
                      <SD SI="Fehlersetzbedingung">Defekt im Flash-Rom erkannt. Ein langsam laufender Hintergrundprozess berechnet zyklisch die Checksum über den kompletten Flash-Rom Inhalt und vergleicht dies mit der ebenfalls am im Flash-Rom abgelegten Checksum.</SD>
                      <SD SI="Entstörzeit">keine/nicht zutreffend</SD>
                      <SD SI="Aussetzzeit">keine/nicht zutreffend</SD>
                      <SD SI="Funktionelle Einschränkungen">Eingeschränkte Funktionalität vom Steuergerät</SD>
                      <SD SI="Fehlerbehandlung">Steuergeräte Tausch</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">n/a</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
                      <SD SI="Rücksetzbedingungen">keine/nicht zutreffend</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
                <DTC ID="DTCDOP_VAGUDS.DTC_259">
                  <SHORT-NAME>DTC_259</SHORT-NAME>
                  <TROUBLE-CODE>259</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>B200046</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="B200046">EEPROM_Defect</TEXT>
                  <LEVEL>4</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">keine</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">Zyklisch;Die Überwachung des EEPROMs ist ein Teil der EEPROM Treiber SW. Bei jedem lesenden bzw schreibenden Zugriff wird der für den EPROM Datenblock berechnete CRC mit dem im EEPROM abgelegten CRC verglichen.</SD>
                      <SD SI="Fehlersetzbedingung">Bei jedem lesenden Zugriff auf einem EEPROM Block prüft die Treiber SW, ob der berechnete CRC über dem gelesenen Datenblock mit dem im EEPROM abgelegten CRC übereinstimmt.</SD>
                      <SD SI="Entstörzeit">keine/nicht zutreffend</SD>
                      <SD SI="Aussetzzeit">keine/nicht zutreffend</SD>
                      <SD SI="Funktionelle Einschränkungen">Eingeschränkte Funktionalität vom Steuergerät</SD>
                      <SD SI="Fehlerbehandlung">Steuergeräte Tausch</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">n/a</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
                      <SD SI="Rücksetzbedingungen">keine/nicht zutreffend</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
                <DTC ID="DTCDOP_VAGUDS.DTC_261">
                  <SHORT-NAME>DTC_261</SHORT-NAME>
                  <TROUBLE-CODE>261</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>B200047</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="B200047">Watchdog_Communication</TEXT>
                  <LEVEL>4</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">keine</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">Start up;Nach jedem System Restart wird der Watchdog Reset Counter für das laufende Intervall mit dem zulässigen Maximum verglichen. Nach Ablauf des vordefinierten Zeitintervalls wird der Watchdog Reset Counter für das laufende Intervall wieder auf 0 zurückgesetzt. Bei einem durch den Watchdog ausgelösten Reset darf nicht nur der statische globale Reset Counter um 1 erhöht werden, sondern auch der Watchdog Reset Counter für das laufende Überwachungsintervall muss um 1 inkrementierrt werden.</SD>
                      <SD SI="Fehlersetzbedingung">Das Hoch- und Runterzählen des ErrorCounters innerhalb der Watchdog- / MainController SPI Kommunikation oder einzelne sporadische Watchdog Resets sollen noch nicht als Fehlerurssache gewertet werden, die zu einem Fehlereintrag 'Steuergerät defekt' führen. Zur Auswertung dieses Verhaltens stehen separate Diagnosebefehle, Messwerteblöcke und Debug-Messages zur Verfügung. Ein Fehlerspeichereintrag 'Steuergerät defekt' aufgrund fehlerhafter Watchdog Kommunikation wird erst dann generiert, wenn innerhalb einer bestimmten Zeit (z.B.: 1 Tag) die Anzahl der registrierten Watchdog Resets eine gewisse Schranke (z.B. 100) überschreitet.</SD>
                      <SD SI="Entstörzeit">keine/nicht zutreffend</SD>
                      <SD SI="Aussetzzeit">keine/nicht zutreffend</SD>
                      <SD SI="Funktionelle Einschränkungen">Eingeschränkte Funktionalität des Hauptprozessors</SD>
                      <SD SI="Fehlerbehandlung">Steuergeräte Tausch</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">n/a</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
                      <SD SI="Rücksetzbedingungen">keine/nicht zutreffend</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
                <DTC ID="DTCDOP_VAGUDS.DTC_263">
                  <SHORT-NAME>DTC_263</SHORT-NAME>
                  <TROUBLE-CODE>263</TROUBLE-CODE>
                  <DISPLAY-TROUBLE-CODE>B200096</DISPLAY-TROUBLE-CODE>
                  <TEXT TI="B200096">Dataflash_Defect</TEXT>
                  <LEVEL>4</LEVEL>
                  <SDGS>
                    <SDG>
                      <SD SI="Testbedingung">keine</SD>
                      <SD SI="Interne Signale / Fehlerpfad">keine/nicht zutreffend</SD>
                      <SD SI="Testzyklus">Zyklisch;Überwachung ist permanent aktiv (HW-Funktion des Mikro-Controllers)</SD>
                      <SD SI="Fehlersetzbedingung">Bei jedem lesenden Zugriff auf einen Datenflash-Block wird von der Controller HW automatisch der CRC über die gelesenen Datenbits berechnet und mit den abgelegten und ebenfalls gelesenen CRC-Bits verglichen. Ein Fehler führt zu einer Controller Exception.</SD>
                      <SD SI="Entstörzeit">keine/nicht zutreffend</SD>
                      <SD SI="Aussetzzeit">keine/nicht zutreffend</SD>
                      <SD SI="Funktionelle Einschränkungen">Eingeschränkte Funktion/ keine gesicherte Datenablage möglich</SD>
                      <SD SI="Fehlerbehandlung">Steuergeräte Tausch</SD>
                      <SD SI="Vorhandene Fehler- /Umgebungsdaten">n/a</SD>
                      <SD SI="Warn-Lampen Information">keine/nicht zutreffend</SD>
                      <SD SI="Rücksetzbedingungen">keine/nicht zutreffend</SD>
                    </SDG>
                    <SDG>
                      <SDG>
                        <SD SI="Pin">0</SD>
                        <SD SI="Connector">keine/nicht zutreffend</SD>
                        <SD SI="IO_Desc">n/a</SD>
                        <SD SI="IO">---</SD>
                        <SD SI="Supply">---</SD>
                        <SD SI="Typ">---</SD>
                      </SDG>
                    </SDG>
                  </SDGS>
                </DTC>
