  /begin IF_DATA ETK_XETK

      /begin ETK_XETK_LIST
       /* version   */ ETK_XETK_AML_VERSION_2_0_0
        /begin ETK
          1 /* ETK_XETK_ID   */
          INTERFACE_SPEED_100MBIT /* Interface   */
          CONFIG "CpuType" "TC29xED_A"
