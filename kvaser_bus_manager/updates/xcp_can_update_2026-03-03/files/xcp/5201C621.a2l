    /begin RASTER_CHECK
        OFFLINE_DEVICE 1 /* device with id 1 is the default device for offline raster check */
        ONLINE_RESPECT_OFFLINE_LIMIT
    /end RASTER_CHECK

      /end ETK_XETK_LIST

    /begin TP_BLOB
       /* ByteOrder */ BYTE_ORDER_MSB_LAST

       /begin DISTAB_CFG
         /* Distab Type */ 17
       /end DISTAB_CFG

    /begin ECU_EVENT_LIST
      0xBF1FE7E4 /* start address of ECU event list        */
     ETK_XETK_REF 1 2 3 4 
    /end ECU_EVENT_LIST
    TABLE_ALIGNMENT ALIGNMENT_4_BYTE
    /begin EVENT_CONFIG_OUTPUT_AREA
      0xBF1FB7C0 /* start of event config area */
      12324 /* size in bytes of event config area */
      0xBF1FE7FC /* start of event output area */
      6144 /* size in bytes of event output area */
      ETK_XETK_REF 1 2 3 4 
    /end EVENT_CONFIG_OUTPUT_AREA
    /begin DATA_ACQUISITION
      PRIORITY_RANGE 1 5
      ETK_XETK_REF 1 2 3 4 
    /end DATA_ACQUISITION
    /begin ECU_PROPERTY
      OVERALL_PERFORMANCE 820895 3283580
      CORE_PERFORMANCE 0 149254 597016
      CORE_PERFORMANCE 1 134328 537312
      CORE_PERFORMANCE 2 537313 2149252
      ETK_XETK_REF 1 2 3 4 
    /end ECU_PROPERTY
    /begin TRIGGER_CFG
      TRIGGER 20  DIRECT
      TRIGGER 21  DIRECT
      TRIGGER 22  DIRECT
      TRIGGER 23  DIRECT
      TRIGGER 24  DIRECT
      ETK_XETK_REF 1 2 3 4 
    /end TRIGGER_CFG
    /begin CODE_CHK
      /* Address ECU DATA section   */ 0x80600118
      /* Address ECU RAM section    */ 0xBF1FB784
      /* Length  ECU DATA sections  */ 8
      PATTERN_REFRESH_TIMEOUT 0x200
      ERROR_BEHAVIOR PERMANENT_RESET
      ETK_XETK_REF 1 2 3 4 
    /end CODE_CHK
    /begin COLDSTART_HANDSHAKE
      /* Address of ETKS coldstart pattern */    0xBF1FB79C

      WAIT
        /* Dyn. length for wait pattern    */    0xE5 0xAD 0xEC 0x4D

      READY
        /* Dyn. length for ready pattern    */   0xDE 0xC0 0xED 0xFE

    ETK_XETK_REF 1 2 3 4 
    /end COLDSTART_HANDSHAKE

    /begin PAGE_SWITCH_METHOD
        2               /* version                              */
        MAILBOX
            3           /* MBX_Version                                 */
                        /* Version of mailbox                          */
            200          /* MBX_PageSetupTime                           */
                        /* max time the ECU needs to set up page in ms */
            0xBF1FB7B4  /* MBX_StartAddress                            */
                        /* Start address of table                      */

        AUTOSTART_BEHAVIOR    LAST_ACTIVE_PAGE  /* Table to be filled by INCA with info */
                                                /* for the current active page          */

        OMD
            0xBF1FB6E0     /* OMD_ADDRESS */
            1  /* OMD_CID */
            0  /* OMD_VERSION */
            0xA0   /* OMD_MAX_LEN */
            31  /* OMD_NUMBER_OF_EMU_HANDLES */
        CODE_CHK_PATTERN_WP
            0xBF1FB78C /* Start address of WP CodeCheck Pattern  */
        ETK_XETK_REF 1 2 3 4 
    /end PAGE_SWITCH_METHOD

    /begin ECU_DEFINED_ERRORCODES
          ERROR_ENTRY 0x00000001 "OMD error"
          ERROR_ENTRY 0x45525201 "ECU will be reset - STOP engine!"
          ERROR_ENTRY 0x45525202 "ECU does not support Programming at T15 OFF"
          ERROR_ENTRY 0x45525203 "Mail Box Version is invalid"
          ERROR_ENTRY 0x45525204 "Call Back Function is not configured"
    /end ECU_DEFINED_ERRORCODES

    /begin DATA_FREEZE
      CONFIG  "SAFETY_MAILBOX_ADDRESS" "0xBF1FB7A8" 
      CONFIG  "SAFETY_MAILBOX_VERSION" "0x4D310100" 
      CONFIG  "SAFETY_MAILBOX_WAITMSG" "Datafreeze is pending" 
      CONFIG  "SAFETY_MAILBOX_WAITTOUT" "2000" 
      CONFIG  "STARTUP_MAILBOX_ADDRESS" "0x7001DE00" 
      CONFIG  "STARTUP_MAILBOX_VERSION" "0x4D320100" 
      CONFIG  "VALIDATE_PATTERN" "0x80600000 0x100" 
      CONFIG  "INVALIDATE_PATTERN" "0x80600120 0x00044408000004009011000208408C0090508808031010614000280812047640" 
       ETK_XETK_REF 1 2 3 4 
    /end DATA_FREEZE

    /end TP_BLOB
    
    /begin SOURCE
      /* daq name        */ "1ms time synchronous"
      /* period unit CSE */ 3
      /* repetition rate */ 1
      /begin QP_BLOB
        /* RASTER_ID                             */ 1
        /* raster priority [1..32]               */ 5
        /* worst case raster time [us]           */ 900
        /begin ETK_XETK_SPECIFIC
          /* hardware trigger                      */ TRG_NBR 0
        /begin ECU_PROPERTY
            PERFORMANCE  1 89500 358000
        /end ECU_PROPERTY
            ETK_XETK_REF 1 2 3 4
        /end ETK_XETK_SPECIFIC
      /end QP_BLOB
    /end SOURCE
    
    /begin SOURCE
      /* daq name        */ "2p5ms time synchronous"
      /* period unit CSE */ 3
      /* repetition rate */ 1
      /begin QP_BLOB
        /* RASTER_ID                             */ 2
