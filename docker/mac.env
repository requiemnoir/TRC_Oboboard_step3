# Profilo Docker Mac (sviluppo locale, traffico simulato)
COMPOSE_PROJECT_NAME=trc-onboard-mac

# mirror_logger
MIRROR_LOGGER_TOKEN=dev-mirror-mac
MIRROR_FAKE=1
MIRROR_LOGGER_WATCHDOG=1

# kvaser_bus_manager
KBSM_AUTOSTART=0
KBSM_AUTO_START_LOGGING=0
KBSM_VEHICLE_MODE=0
KBSM_RESTORE_ARMED=0
KBSM_HOST=0.0.0.0
KBSM_PORT=5000
KVBM_HOST_PORT=5001
MF4_FLUSH_INTERVAL_MB=5
MF4_CHUNK_INTERVAL_S=15
MF4_MERGE_ON_STOP=0
MF4_INCREMENTAL_MERGE=0
LOG_FLUSH_INTERVAL_S=1
LOG_FSYNC=1
KBSM_MIN_FREE_DISK_MB=256
KBSM_RX_QUEUE_MAX=131072
